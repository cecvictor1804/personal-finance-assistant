# Copy to .env for local dev. In production these come from Secret Manager / Cloud Run env.

# --- Plaid ---
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox            # sandbox | production
PLAID_PRODUCTS=transactions,investments,liabilities
PLAID_COUNTRY_CODES=US

# --- Firebase / GCP ---
GCP_PROJECT_ID=your-gcp-project
# Path to a service-account key for local dev. In Cloud Run, use the attached
# service account instead (leave unset).
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json
# Cloud KMS key that wraps Plaid access tokens (projects/.../cryptoKeys/...).
KMS_KEY_NAME=
# Document AI Expense parser processor for receipt OCR (Phase 6).
DOCAI_PROCESSOR_NAME=projects/your-gcp-project/locations/us/processors/your-processor-id

# --- App ---
APP_ENV=local                # local | dev | prod
# Comma-separated CORS origins for the web dashboard.
CORS_ORIGINS=http://localhost:5173
# When true (local only), the Firebase ID-token check is bypassed and DEV_UID is used.
AUTH_DISABLED=false
DEV_UID=dev-user

# --- Alerts (Phase 3) ---
LARGE_TXN_THRESHOLD_CENTS=50000      # $500
BUDGET_WARN_PERCENT=80
