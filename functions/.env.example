# Cloud Functions runtime env (set via `firebase functions:config` or Secret Manager in prod).
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions,investments,liabilities
PLAID_COUNTRY_CODES=US
PLAID_WEBHOOK_URL=https://<region>-<project>.cloudfunctions.net/plaid_webhook

GCP_PROJECT=your-gcp-project
KMS_KEY_NAME=projects/your-gcp-project/locations/us/keyRings/pfa/cryptoKeys/plaid-tokens
PLAID_SYNC_TOPIC=plaid-sync
